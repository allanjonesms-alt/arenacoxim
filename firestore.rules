rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isMaster() {
      return isAuthenticated() && 
             (request.auth.token.email.lower() == "allanjonesms@gmail.com");
    }
    
    function isAdmin() {
      return isMaster() || exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Rules
    function isValidLocation(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() <= 100 &&
             (data.get('address', '') is string) &&
             (data.get('playerCount', 5) is number) &&
             (data.get('gameDuration', 60) is number) &&
             (data.get('allowSubstitutes', false) is bool) &&
             (data.get('substitutesCount', 0) is number);
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['date', 'time', 'locationId', 'status', 'createdAt']) &&
             data.date is string && data.time is string &&
             data.locationId is string &&
             data.status in ['scheduled', 'live', 'finished'] &&
             data.createdAt is number;
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidMatch(request.resource.data);
      allow delete: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /locations/{locationId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidLocation(request.resource.data);
      allow delete: if isAdmin();
    }

    // Admins helper
    function isValidAdmin(data) {
      return data.keys().hasAll(['name', 'email', 'locationId', 'role', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.locationId is string &&
             data.role in ['admin', 'master'] &&
             data.createdAt is number;
    }

    match /admins/{adminId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      allow create: if (isMaster() && isValidAdmin(request.resource.data)) || 
                    (isAuthenticated() && request.auth.uid == adminId && 
                     request.resource.data.email == request.auth.token.email &&
                     isValidAdmin(request.resource.data));
      allow update: if isMaster() || (isAuthenticated() && request.auth.uid == adminId);
      allow delete: if isMaster();
    }

    match /settings/scoring {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
