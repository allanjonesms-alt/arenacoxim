rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isMaster() {
      return isEmailVerified() && 
             (request.auth.token.email.lower() == "allanjonesms@gmail.com");
    }

    function isAdmin() {
      return isMaster() || exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Specific Validators ---

    function isValidPlayer(data) {
      return data.keys().hasAll(['name', 'position']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.position in ['goleiro', 'defensor', 'atacante'] &&
             (!data.keys().contains('nickname') || (data.nickname is string && data.nickname.size() <= 100)) &&
             (!data.keys().contains('photoUrl') || (data.photoUrl is string && data.photoUrl.size() <= 1000));
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['date', 'time', 'locationId', 'status', 'createdAt']) &&
             data.date is string && data.time is string &&
             data.locationId is string &&
             data.status in ['scheduled', 'live', 'finished'] &&
             data.createdAt is number;
    }

    function isValidLocation(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 150;
    }

    function isValidAdminEntry(data) {
      return data.keys().hasAll(['name', 'email', 'locationId', 'role']) &&
             data.name is string && data.email is string &&
             data.role in ['admin', 'master'];
    }

    function isValidTeam(data) {
      return data.keys().hasAll(['name', 'locationId']) &&
             data.name is string && data.name.size() > 0 &&
             data.locationId is string;
    }

    // --- Routes ---

    match /players/{playerId} {
      allow read, list: if true;
      allow create, update: if isAdmin() && isValidPlayer(incoming());
      allow delete: if isAdmin();
    }

    match /matches/{matchId} {
      allow read, list: if true;
      allow create, update: if isAdmin() && isValidMatch(incoming());
      allow delete: if isAdmin();
    }

    match /teams/{teamId} {
      allow read, list: if true;
      allow create, update: if isAdmin() && isValidTeam(incoming());
      allow delete: if isAdmin();
    }

    match /locations/{locationId} {
      allow read, list: if true;
      allow create, update: if isAdmin() && isValidLocation(incoming());
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update: if (isMaster() || (isSignedIn() && request.auth.uid == adminId)) && isValidAdminEntry(incoming());
      allow delete: if isMaster();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
