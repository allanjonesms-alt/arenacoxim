{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "A player in the amateur football group",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the player" },
        "nickname": { "type": "string", "description": "Nickname of the player" },
        "position": { "type": "string", "enum": ["goleiro", "defensor", "atacante"], "description": "Player's preferred position" },
        "gmail": { "type": "string", "description": "Player's Google email for authentication linkage" },
        "phone": { "type": "string", "description": "Player's phone/WhatsApp number" },
        "photoUrl": { "type": "string", "description": "URL to player's photo" },
        "cardBgUrl": { "type": "string", "description": "Dynamic background card theme image URL/base64" },
        "stats": {
          "type": "object",
          "properties": {
            "wins": { "type": "integer" },
            "goals": { "type": "integer" },
            "assists": { "type": "integer" },
            "matches": { "type": "integer" }
          }
        },
        "overallStats": {
          "type": "object",
          "properties": {
            "speed": { "type": "integer" },
            "stamina": { "type": "integer" },
            "strength": { "type": "integer" },
            "shooting": { "type": "integer" },
            "dribbling": { "type": "integer" },
            "passing": { "type": "integer" }
          }
        }
      },
      "required": ["name", "position"]
    },
    "Match": {
      "title": "Match",
      "description": "A football match (pelada)",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "locationId": { "type": "string" },
        "teamAId": { "type": "string" },
        "teamBId": { "type": "string" },
        "teamA": { "type": "array", "items": { "type": "string" } },
        "teamB": { "type": "array", "items": { "type": "string" } },
        "confirmedPlayers": { "type": "array", "items": { "type": "string" } },
        "goalkeeperAId": { "type": "string" },
        "goalkeeperBId": { "type": "string" },
        "scoreA": { "type": "integer" },
        "scoreB": { "type": "integer" },
        "substitutesCount": { "type": "integer" },
        "status": { "type": "string", "enum": ["scheduled", "live", "finished"] },
        "mvpId": { "type": "string", "description": "ID of the match MVP" },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "playerId": { "type": "string" },
              "type": { "type": "string", "enum": ["goal", "assist"] }
            }
          }
        },
        "createdAt": { "type": "integer" }
      },
      "required": ["date", "time", "locationId", "status", "createdAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "User with administrative privileges",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "locationId": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["name", "email", "locationId"]
    },
    "Team": {
      "title": "Team",
      "description": "A football team",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the team" },
        "location": { "type": "string", "description": "Home location of the team" },
        "color": { "type": "string", "description": "Primary color of the team jersey" }
      },
      "required": ["name", "location", "color"]
    },
    "Location": {
      "title": "Location",
      "description": "A football field or arena",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the location" },
        "address": { "type": "string", "description": "Full address of the location" },
        "logoUrl": { "type": "string", "description": "URL or base64 of the location logo" },
        "playerCount": { "type": "integer", "description": "Players per team in a match" },
        "gameDuration": { "type": "integer", "description": "Duration in minutes" },
        "allowSubstitutes": { "type": "boolean" },
        "substitutesCount": { "type": "integer" }
      },
      "required": ["name"]
    },
    "ScoringRules": {
      "title": "Scoring Rules",
      "description": "Rules for calculating player points",
      "type": "object",
      "properties": {
        "win": { "type": "integer" },
        "draw": { "type": "integer" },
        "goal": { "type": "integer" },
        "assist": { "type": "integer" },
        "cleanSheet": { "type": "integer" },
        "mvp": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["win", "draw", "goal", "assist", "cleanSheet", "mvp"]
    },
    "News": {
      "title": "News",
      "description": "Fast news for the home page",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "integer" },
        "link": { "type": "string", "description": "Optional news external or detail link" }
      },
      "required": ["title", "content", "createdAt"]
    },
    "Card": {
      "title": "Card",
      "description": "Custom card background images representing themes for athletes",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["name", "imageUrl", "createdAt"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Advertising or informational banner",
      "type": "object",
      "properties": {
        "imageUrlDesktop": { "type": "string", "description": "Base64 or URL of desktop image" },
        "imageUrlMobile": { "type": "string", "description": "Base64 or URL of mobile image" },
        "link": { "type": "string", "description": "Destination URL on click" },
        "active": { "type": "boolean", "description": "Whether banner is active and visible" },
        "clicks": { "type": "integer", "description": "Total number of clicks" },
        "createdAt": { "type": "integer", "description": "Timestamp when banner was created" }
      },
      "required": ["imageUrlDesktop", "imageUrlMobile", "link", "active"]
    }
  },
  "firestore": {
    "/players/{playerId}": {
      "schema": "Player",
      "description": "Collection of players"
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Collection of matches"
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "Collection of administrators"
    },
    "/teams/{teamId}": {
      "schema": "Team",
      "description": "Collection of teams"
    },
    "/locations/{locationId}": {
      "schema": "Location",
      "description": "Collection of playing locations"
    },
    "/settings/scoring": {
      "schema": "ScoringRules",
      "description": "Global scoring rules configuration"
    },
    "/news/{newsId}": {
      "schema": "News",
      "description": "Collection of fast news"
    },
    "/cards/{cardId}": {
      "schema": "Card",
      "description": "Collection of custom athlete card backgrounds"
    },
    "/banners/{bannerId}": {
      "schema": "Banner",
      "description": "Collection of promotional/informational banners"
    }
  }
}
